# Optional: OMDb API key for ratings/plot metadata
VITE_OMDB_API_KEY=

# Fallback only (client-visible): use only if you cannot deploy the server proxy
VITE_TMDB_API_KEY=

# Server-side only (do NOT prefix with VITE_)
# Configure this in your hosting platform env vars for /api/tmdb/poster
TMDB_READ_ACCESS_TOKEN=
